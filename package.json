{
	"name": "the-croax",
	"version": "0.1.0",
	"homepage": "https://sanderdrummer.github.io/the-croax",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build && touch out/.nojekyll",
		"start": "npx serve@latest out",
		"check": "npx @biomejs/biome check --write .",
		"deploy": "npx gh-pages -d out",
		"images": "node process-images.mjs",
		"update": "npx npm-check-updates --interactive",
		"lint": "eslint",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"dependencies": {
		"@heroicons/react": "^2.2.0",
		"gray-matter": "^4.0.3",
		"next": "16.2.4",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"remark": "^15.0.1",
		"remark-html": "^16.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/typography": "^0.5.19",
		"@types/node": "^25",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"autoprefixer": "^10.5.0",
		"postcss": "^8.5.10",
		"sharp": "^0.34.5",
		"tailwindcss": "^3.4.18",
		"typescript": "^6"
	}
}
